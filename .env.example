# =========================================================
# MindCare AI X - Environment Configurations Template
# Copy this file to .env and configure secret keys
# =========================================================

# MongoDB Connection Configuration
MONGODB_URL=mongodb://localhost:27017/mindcare_ai
MONGODB_DB=mindcare_ai

# JWT Security Secrets (Minimum 32 characters)
JWT_SECRET_KEY=generate_your_secure_random_jwt_secret_key_here_32_chars

# IBM Watsonx AI Granite Service Provider Credentials
IBM_WATSONX_APIKEY=your_ibm_watsonx_cloud_iam_apikey
IBM_WATSONX_PROJECT_ID=your_ibm_watsonx_granite_project_id
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Frontend Endpoint (For REST Client communication)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
