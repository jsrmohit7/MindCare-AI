# =========================================================
# MindCare AI - Environment Configuration Example
# =========================================================

# FastAPI Server configurations
DEBUG=False
CORS_ORIGINS=http://localhost:3000

# MongoDB connection configurations
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=mindcare_ai

# IBM Watsonx.ai credentials (REQUIRED FOR PIPELINE INFERENCE)
# Replace with valid credentials in your local .env file. Do not commit secrets.
IBM_API_KEY=your_ibm_watsonx_api_key_here
IBM_PROJECT_ID=your_ibm_watsonx_project_id_here
IBM_URL=https://us-south.ml.cloud.ibm.com
IBM_GRANITE_MODEL=ibm/granite-13b-instruct-v2

# Watsonx Request Configurations
IBM_TIMEOUT_SECONDS=30.0
IBM_MAX_NEW_TOKENS=1000
